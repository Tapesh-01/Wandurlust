<% layout("/layouts/boilerplate") %>

<style>
    .checkout-container {
        max-width: 500px;
        margin: 50px auto;
        font-family: 'Inter', sans-serif;
    }
    .checkout-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        border: none;
    }
    .checkout-header {
        background: #121212;
        color: #fff;
        padding: 20px;
        text-align: center;
    }
    .checkout-body {
        padding: 30px;
    }
    .amount-box {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        text-align: center;
    }
    .amount-label {
        font-size: 14px;
        color: #666;
        display: block;
    }
    .amount-value {
        font-size: 28px;
        font-weight: 700;
        color: #333;
    }
    .payment-options {
        margin-bottom: 30px;
    }
    .payment-option {
        display: flex;
        align-items: center;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        margin-bottom: 10px;
        cursor: pointer;
        transition: 0.3s;
    }
    .payment-option:hover {
        border-color: #fe424d;
        background: #fff5f5;
    }
    .payment-option i {
        margin-right: 15px;
        font-size: 20px;
        color: #555;
    }
    .btn-pay {
        background: #fe424d;
        color: #fff;
        border: none;
        width: 100%;
        padding: 15px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 16px;
        transition: 0.3s;
    }
    .btn-pay:hover {
        background: #e03a44;
        transform: translateY(-2px);
    }
    
    /* Processing Screen */
    #processing-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.95);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        display: none;
    }
    .spinner {
        width: 60px;
        height: 60px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #fe424d;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 20px;
    }
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

<div class="checkout-container">
    <div class="checkout-card">
        <div class="checkout-header">
            <h4 class="mb-0">Secure Checkout</h4>
        </div>
        <div class="checkout-body">
            <p class="text-center text-muted mb-4">Complete your payment for <b><%= listingTitle %></b></p>
            
            <div class="amount-box">
                <span class="amount-label">Amount to Pay</span>
                <span class="amount-value">₹<%= amount.toLocaleString("en-IN") %></span>
            </div>

            <div class="payment-options">
                <h6>Select Payment Method</h6>
                <div class="payment-option">
                    <i class="fa-solid fa-credit-card"></i>
                    <span>Credit / Debit Card</span>
                </div>
                <div class="payment-option">
                    <i class="fa-brands fa-google-pay"></i>
                    <span>UPI (Google Pay, PhonePe)</span>
                </div>
                <div class="payment-option">
                    <i class="fa-solid fa-building-columns"></i>
                    <span>Net Banking</span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn-pay flex-grow-1" onclick="simulatePayment('success')">Proceed to Pay</button>
                <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" class="flex-grow-1">
                    <button type="submit" class="btn btn-outline-dark w-100 py-3" style="border-radius: 8px; font-weight: 600;"
                        onclick="return confirm('Are you sure you want to cancel this booking? Yours dates will be freed for others.')">
                        Cancel
                    </button>
                </form>
            </div>
            
            <p class="text-center mt-3 mb-0">
                <a href="#" class="text-muted small" onclick="simulatePayment('failure')">Simulate Failed Transaction</a>
            </p>
        </div>
    </div>
</div>

<div id="processing-screen">
    <div class="spinner"></div>
    <h4>Verifying with Secure Gateway...</h4>
    <p class="text-muted">Please do not refresh or close the window.</p>
</div>

<form id="simulation-form" action="/bookings/simulate-payment" method="POST" style="display: none;">
    <input type="hidden" name="booking_id" value="<%= booking._id %>">
    <input type="hidden" name="status" id="sim-status">
</form>

<script>
    function simulatePayment(status) {
        document.getElementById('sim-status').value = status;
        document.getElementById('processing-screen').style.display = 'flex';
        
        // Add a realistic delay
        setTimeout(() => {
            document.getElementById('simulation-form').submit();
        }, 3000);
    }
</script>
