<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-10 offset-1">
        <h3 class="mb-1"><i class="fa-solid fa-house-chimney"></i> Host Dashboard</h3>
        <p class="text-muted mb-4">Bookings received on your listings</p>

        <% if (listings.length === 0) { %>
            <div class="text-center py-5">
                <i class="fa-solid fa-house-circle-xmark" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3 text-muted">You have no listings yet</h4>
                <p class="text-muted">Create a listing to start hosting!</p>
                <a href="/listings/new" class="btn reserve-btn mt-3">Add Listing</a>
            </div>

        <% } else if (bookings.length === 0) { %>
            <div class="text-center py-5">
                <i class="fa-regular fa-calendar-xmark" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3 text-muted">No bookings yet on your listings</h4>
                <p class="text-muted">When someone books your listing, it will appear here.</p>
            </div>

        <% } else { %>
            <!-- Summary Cards -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card text-center p-3 border-0 shadow-sm">
                        <h2 class="text-danger mb-0">
                            <%= bookings.filter(b => (!b.status || b.status === 'active')).length %>
                        </h2>
                        <p class="text-muted mb-0">Total Bookings</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center p-3 border-0 shadow-sm">
                        <h2 class="text-success mb-0">
                            ₹<%= bookings.reduce((sum, b) => {
                                const isActive = !b.status || b.status === 'active';
                                return isActive ? sum + b.totalPrice : sum;
                            }, 0).toLocaleString('en-IN') %>
                        </h2>
                        <p class="text-muted mb-0">Total Earnings</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center p-3 border-0 shadow-sm">
                        <h2 class="text-primary mb-0"><%= listings.length %></h2>
                        <p class="text-muted mb-0">Your Listings</p>
                    </div>
                </div>
            </div>

            <!-- Bookings Table -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Listing</th>
                                    <th>Guest</th>
                                    <th>Check-in</th>
                                    <th>Check-out</th>
                                    <th>Guests</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Condition</th>
                                    <th>Booked On</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for (let booking of bookings) { %>
                                    <tr>
                                        <td>
                                            <a href="/listings/<%= booking.listing._id %>" class="text-decoration-none text-dark fw-semibold">
                                                <img src="<%= (booking.listing.images && booking.listing.images.length > 0) ? booking.listing.images[0].url : (booking.listing.image && booking.listing.image.url) ? booking.listing.image.url : 'https://placehold.co/40x40/ffe4e6/fe424d?text=?' %>" alt="" style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px;" class="me-2">
                                                <%= booking.listing.title %>
                                            </a>
                                        </td>
                                        <td>
                                            <i class="fa-solid fa-user text-muted me-1"></i>
                                            <%= booking.user ? booking.user.username : "Unknown" %>
                                        </td>
                                        <td><%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                        <td><%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                        <td><%= booking.guests %></td>
                                        <td class="text-success fw-bold">₹<%= booking.totalPrice.toLocaleString('en-IN') %></td>
                                        <td>
                                            <% if (booking.isNewBooking) { %>
                                                <span class="badge bg-danger rounded-pill">New!</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary rounded-pill">Viewed</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (booking.status === 'cancelled_by_host') { %>
                                                <span class="text-danger fw-bold"><i class="fa-solid fa-ban"></i> You Cancelled</span>
                                            <% } else if (booking.status === 'cancelled_by_guest') { %>
                                                <span class="text-warning fw-bold"><i class="fa-solid fa-user-xmark"></i> Guest Cancelled</span>
                                            <% } else { %>
                                                <% if (new Date() > new Date(booking.checkOut)) { %>
                                                    <span class="text-info fw-bold" style="color: #00838f !important;"><i class="fa-solid fa-clock-rotate-left"></i> Completed</span>
                                                <% } else { %>
                                                    <span class="text-success fw-bold"><i class="fa-solid fa-circle-check"></i> Active</span>
                                                <% } %>
                                            <% } %>
                                        </td>
                                        <td class="text-muted small"><%= new Date(booking.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                                        <td>
                                            <% 
                                              const isPast = new Date() > new Date(booking.checkOut); 
                                              const isActive = !booking.status || booking.status === 'active';
                                            %>
                                            <% if (isActive && !isPast) { %>
                                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#hostCancelModal-<%= booking._id %>">
                                                    Cancel
                                                </button>
                                                
                                                <!-- Host Cancel Modal -->
                                                <div class="modal fade" id="hostCancelModal-<%= booking._id %>" tabindex="-1" aria-labelledby="hostCancelModalLabel-<%= booking._id %>" aria-hidden="true">
                                                  <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content">
                                                      <div class="modal-header border-0 pb-0">
                                                        <h5 class="modal-title text-danger" id="hostCancelModalLabel-<%= booking._id %>"><i class="fa-solid fa-triangle-exclamation"></i> Cancel Guest Booking</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                      </div>
                                                      <div class="modal-body pb-2 text-start p-3 text-wrap text-break" style="max-height: 200px; overflow-y: auto;">
                                                        Are you sure you want to cancel the booking for <b style="color:black;"><%= booking.user ? booking.user.username : 'Unknown' %></b> at <b style="color:black;"><%= booking.listing.title %></b>?
                                                      </div>
                                                      <div class="modal-footer border-0 pt-0">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Keep Booking</button>
                                                        <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" id="hostCancelForm-<%= booking._id %>" class="m-0" onsubmit="event.preventDefault(); const form = this; const btn = form.querySelector('button'); btn.disabled = true; btn.innerHTML = '<i class=\'fa-solid fa-spinner fa-spin\'></i> Cancelling...'; setTimeout(() => { form.submit(); }, 3000);">
                                                            <button type="submit" class="btn btn-danger">Yes, Cancel Booking</button>
                                                        </form>
                                                      </div>
                                                    </div>
                                                  </div>
                                                </div>
                                            <% } else if (!isActive) { %>
                                                <button class="btn btn-sm btn-outline-secondary" disabled>Cancelled</button>
                                            <% } else { %>
                                                <button class="btn btn-sm btn-outline-secondary" disabled>Completed</button>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</div>
