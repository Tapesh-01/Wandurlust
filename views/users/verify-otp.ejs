<% layout("/layouts/boilerplate") %>
<style>
    .auth-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .auth-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 2rem;
        padding: 3rem;
        box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 480px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    [data-theme="dark"] .auth-card {
        background: rgba(20, 20, 20, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.4);
    }
    .auth-title {
        font-weight: 800;
        margin-bottom: 0.5rem;
        font-size: 2.2rem;
        background: linear-gradient(45deg, #fe424d, #ff7e5f);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .auth-subtitle {
        color: #6c757d;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }
    [data-theme="dark"] .auth-subtitle {
        color: #adb5bd;
    }
    .form-label {
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .form-control {
        border-radius: 1rem;
        padding: 0.85rem 1.2rem;
        border: 2px solid rgba(0,0,0,0.05);
        background: rgba(255,255,255,0.8);
        transition: all 0.3s ease;
    }
    [data-theme="dark"] .form-control {
        background: rgba(255,255,255,0.05);
        border: 2px solid rgba(255,255,255,0.05);
        color: white;
    }
    .form-control:focus {
        border-color: #fe424d;
        box-shadow: 0 0 0 0.25rem rgba(254, 66, 77, 0.1);
    }
    .btn-auth {
        background: linear-gradient(45deg, #fe424d, #ff7e5f);
        border: none;
        border-radius: 1rem;
        padding: 1rem;
        font-weight: 700;
        color: white;
        width: 100%;
        margin-top: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(254, 66, 77, 0.3);
    }
    .btn-auth:hover {
        transform: scale(1.02);
        box-shadow: 0 6px 20px rgba(254, 66, 77, 0.4);
    }
    .otp-input-group {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 1.5rem;
    }
    .otp-field {
        width: 45px;
        height: 55px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: 800;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Verify OTP</h2>
        <p class="auth-subtitle">We've sent a 6-digit code to <b><%= email %></b>. Enter it below to reset your password.</p>
        
        <form action="/verify-otp" method="POST" class="needs-validation" novalidate>
            <input type="hidden" name="email" value="<%= email %>">
            
            <div class="mb-4">
                <label class="form-label">Enter 6-Digit OTP</label>
                <input
                    name="otp"
                    type="text"
                    class="form-control text-center fw-bold fs-4"
                    placeholder="· · · · · ·"
                    maxlength="6"
                    pattern="\d{6}"
                    required
                />
                <div class="invalid-feedback">Please enter the 6-digit code.</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">New Password</label>
                <input
                    name="password"
                    id="password"
                    type="password"
                    class="form-control"
                    placeholder="Enter new password"
                    required
                />
            </div>

            <div class="mb-3">
                <label for="confirm" class="form-label">Confirm New Password</label>
                <input
                    name="confirm"
                    id="confirm"
                    type="password"
                    class="form-control"
                    placeholder="Confirm new password"
                    required
                />
            </div>
            
            <button class="btn-auth">Reset Password</button>
        </form>
        
        <div class="mt-4 text-center">
            <p class="text-muted small">Didn't get the code? <a href="/forgot" style="color: #fe424d; font-weight: 600; text-decoration: none;">Try again</a></p>
        </div>
    </div>
</div>
