<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="POST" class="needs-validation" novalidate>
            
            <div class="mb-3">
                <lable for="username" class="form-label">Username</lable>
                <input
                    name="username"
                    id="username"
                    type="text"
                    class="form-control"
                    required
                />
            </div>
            
            <div class="mb-3">
                <lable for="password" class="form-label">Password</lable>
                <input
                    name="password"
                    id="password"
                    type="password"
                    class="form-control"
                    required
                />  
            </div>          
            <div class="mb-3">
                <a href="/forgot" class="text-decoration-none" style="color: #fe424d; font-size: 0.9rem; font-weight: 600;">Forgot Password?</a>
            </div>
            <button class="btn btn-success">Login</button>

        </form>
    </div>
</div>