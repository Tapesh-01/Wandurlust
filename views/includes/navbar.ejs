<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-solid fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="navbar-nav mx-auto">
        <form method="GET" action="/listings" class="d-flex" role="search">
          <input class="form-control me-2 search-input rounded-pill shadow-sm" type="search" name="search" placeholder="Search destinations..."
              value="<%= typeof search !== 'undefined' ? search : '' %>" style="width: 250px;" />
          <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-magnifying-glass me-2"></i>Search
          </button>
        </form>
      </div>

      <div class="navbar-nav ms-auto align-items-center">
        <a class="nav-link me-3 d-none d-lg-block" href="/listings/new">Add Listing</a>
        
        <!-- Notification Dropdown -->
        <div class="nav-item dropdown d-none d-md-block">
          <div class="notification-bell" id="notificationMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fa-regular fa-bell"></i>
            <% if(typeof globalNewBookingsCount !== 'undefined' && globalNewBookingsCount > 0) { %>
              <div class="bell-badge"></div>
            <% } %>
          </div>
          <ul class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="notificationMenu">
            <li class="dropdown-header d-flex justify-content-between align-items-center">
              <span class="fs-6">Notifications</span>
              <% if(typeof globalNewBookingsCount !== 'undefined' && globalNewBookingsCount > 0) { %>
                <span class="badge bg-danger rounded-pill"><%= globalNewBookingsCount %> New</span>
              <% } %>
            </li>
            <li><hr class="dropdown-divider"></li>
            <% if(typeof globalNewBookings !== 'undefined' && globalNewBookings.length > 0) { %>
              <% for(let booking of globalNewBookings) { %>
                <li>
                  <a class="dropdown-item notification-item" href="/host/bookings">
                    <div class="d-flex align-items-start gap-3">
                      <div class="noti-icon bg-info-subtle"><i class="fa-solid fa-calendar-check text-info"></i></div>
                      <div>
                        <p class="mb-0 fw-semibold text-wrap">New Booking: <%= booking.listing ? booking.listing.title : 'Listing' %></p>
                        <small class="text-muted text-wrap"><%= booking.user ? booking.user.username : 'A guest' %> booked for <%= booking.guests %> guests.</small>
                      </div>
                    </div>
                  </a>
                </li>
              <% } %>
            <% } else { %>
               <li><p class="dropdown-item text-center text-muted mb-0 py-3">No new notifications</p></li>
            <% } %>

            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-center text-primary fw-semibold py-2" href="/host/bookings">See All Activity</a></li>
          </ul>
        </div>

        <!-- User Profile Dropdown -->
        <div class="nav-item dropdown">
          <div class="nav-user-menu" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
             <i class="fa-solid fa-bars" style="font-size: 0.9rem; color: #222222;"></i>
             <div class="user-icon">
                <i class="fa-solid fa-circle-user"></i>
             </div>
          </div>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
            <% if(!currUser) { %>
              <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#signupModal"><b>Sign up</b></a></li>
              <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#loginModal">Log in</a></li>
            <% } else { %>
              <li><h6 class="dropdown-header">Hello, <%= currUser.username %>!</h6></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/bookings">Your Bookings</a></li>
              <% if(typeof currUserIsHost !== 'undefined' && currUserIsHost) { %>
                <li><a class="dropdown-item" href="/host/bookings">Host Dashboard 
                  <% if(typeof globalNewBookingsCount !== 'undefined' && globalNewBookingsCount > 0) { %>
                    <span class="badge bg-danger rounded-pill ms-1"><%= globalNewBookingsCount %></span>
                  <% } %>
                </a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/logout">Log out</a></li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</nav>