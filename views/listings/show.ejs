<% layout("/layouts/boilerplate") %>
  <!-- ═══ Professional Image Gallery Carousel ═══ -->
  <div class="gallery-wrapper col-8 offset-2 mt-4 mb-3">
    <% 
      // Backward compat: support both old `image` field and new `images[]` array
      let imgs = [];
      if (listing.images && listing.images.length > 0) {
        imgs = listing.images;
      } else if (listing.image && listing.image.url) {
        imgs = [listing.image]; // wrap old single image in array
      }
    %>
    
    <% if (imgs.length > 0) { %>
      <!-- Main Carousel -->
      <div id="listingCarousel" class="carousel slide carousel-fade gallery-carousel" data-bs-ride="carousel">
        <!-- Image Counter Badge -->
        <div class="gallery-counter">
          <i class="fa-solid fa-images me-1"></i>
          <span id="carouselCounter">1</span> / <%= imgs.length %>
        </div>

        <!-- Slides -->
        <div class="carousel-inner gallery-inner">
          <% imgs.forEach(function(img, i) { %>
            <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
              <img src="<%= img.url %>" class="d-block w-100 gallery-main-img" alt="Listing photo <%= i+1 %>">
            </div>
          <% }); %>
        </div>

        <!-- Navigation Arrows (only if more than 1 image) -->
        <% if (imgs.length > 1) { %>
          <button class="carousel-control-prev gallery-control" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
            <span class="gallery-arrow-btn"><i class="fa-solid fa-chevron-left"></i></span>
          </button>
          <button class="carousel-control-next gallery-control" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
            <span class="gallery-arrow-btn"><i class="fa-solid fa-chevron-right"></i></span>
          </button>
        <% } %>
      </div>

      <!-- Thumbnail Strip -->
      <% if (imgs.length > 1) { %>
        <div class="gallery-thumbs mt-2 d-flex gap-2">
          <% imgs.forEach(function(img, i) { %>
            <img
              src="<%= img.url %>"
              class="gallery-thumb <%= i === 0 ? 'active' : '' %>"
              data-index="<%= i %>"
              alt="Thumb <%= i+1 %>"
            >
          <% }); %>
        </div>
      <% } %>

    <% } else { %>
      <div class="gallery-placeholder">
        <i class="fa-solid fa-image fa-3x mb-3"></i>
        <p>No images uploaded yet</p>
      </div>
    <% } %>
  </div>

  <!-- Gallery CSS -->
  <style>
    .gallery-wrapper { position: relative; }
    .gallery-carousel { border-radius: 1.2rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
    .gallery-inner { background: #111; }
    .gallery-main-img {
      height: 480px;
      object-fit: cover;
      transition: transform 0.4s ease;
      cursor: zoom-in;
    }
    .gallery-main-img:hover { transform: scale(1.03); }
    .gallery-counter {
      position: absolute;
      top: 14px;
      right: 16px;
      background: rgba(0,0,0,0.55);
      color: #fff;
      padding: 4px 12px;
      border-radius: 2rem;
      font-size: 0.85rem;
      font-weight: 600;
      z-index: 20;
      backdrop-filter: blur(6px);
    }
    .gallery-control { width: auto; padding: 0 10px; }
    .gallery-arrow-btn {
      background: rgba(255,255,255,0.92);
      color: #222;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      transition: all 0.2s ease;
    }
    .gallery-arrow-btn:hover { background: #fff; transform: scale(1.1); box-shadow: 0 4px 14px rgba(0,0,0,0.25); }
    .gallery-thumbs { overflow-x: auto; padding-bottom: 4px; scrollbar-width: thin; }
    .gallery-thumb {
      width: 80px;
      height: 60px;
      object-fit: cover;
      border-radius: 0.6rem;
      cursor: pointer;
      opacity: 0.6;
      border: 2px solid transparent;
      transition: all 0.2s ease;
      flex-shrink: 0;
    }
    .gallery-thumb:hover { opacity: 0.9; }
    .gallery-thumb.active { opacity: 1; border-color: #fe424d; }
    .gallery-placeholder {
      height: 340px;
      background: var(--footer-bg);
      border-radius: 1.2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--secondary-text);
    }
    /* Lightbox overlay */
    .gallery-lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.92);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }
    .gallery-lightbox.open { display: flex; }
    .lightbox-img { max-width: 90vw; max-height: 90vh; border-radius: 0.8rem; object-fit: contain; }
    .lightbox-close {
      position: absolute;
      top: 20px; right: 24px;
      color: #fff;
      font-size: 2rem;
      cursor: pointer;
      background: none;
      border: none;
    }
  </style>

  <!-- Lightbox Overlay -->
  <div class="gallery-lightbox" id="galleryLightbox">
    <button class="lightbox-close" id="lightboxClose"><i class="fa-solid fa-xmark"></i></button>
    <img src="" alt="Fullscreen view" class="lightbox-img" id="lightboxImg">
  </div>

  <!-- Gallery JS -->
  <script>
    (function() {
      const carousel = document.getElementById('listingCarousel');
      if (!carousel) return;

      const counter = document.getElementById('carouselCounter');
      const thumbs = document.querySelectorAll('.gallery-thumb');
      const mainImgs = document.querySelectorAll('.gallery-main-img');
      const lightbox = document.getElementById('galleryLightbox');
      const lightboxImg = document.getElementById('lightboxImg');
      const lightboxClose = document.getElementById('lightboxClose');

      // Update counter & active thumb on carousel slide
      carousel.addEventListener('slid.bs.carousel', function(e) {
        const idx = e.to;
        if (counter) counter.textContent = idx + 1;
        thumbs.forEach((t, i) => t.classList.toggle('active', i === idx));
      });

      // Click thumb → jump to slide
      thumbs.forEach(thumb => {
        thumb.addEventListener('click', function() {
          const bsCarousel = bootstrap.Carousel.getOrCreateInstance(carousel);
          bsCarousel.to(parseInt(this.dataset.index));
        });
      });

      // Click main image → open lightbox
      mainImgs.forEach(img => {
        img.addEventListener('click', function() {
          lightboxImg.src = this.src;
          lightbox.classList.add('open');
          document.body.style.overflow = 'hidden';
        });
      });

      // Close lightbox
      if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
      if (lightbox) lightbox.addEventListener('click', function(e) {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeLightbox();
      });
      function closeLightbox() {
        lightbox.classList.remove('open');
        document.body.style.overflow = '';
      }
    })();
  </script>

  <!-- Listing Info Card -->
  <div class="col-8 offset-2">
    <h3 class="mt-2"><%= listing.title %></h3>
    <p class="text-muted mb-1">
      <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
      &nbsp;·&nbsp;<i class="fa-solid fa-users me-1"></i>Up to <%= listing.maxGuests %> guests
      &nbsp;·&nbsp;<i class="fa-solid fa-tag me-1"></i><%= listing.category %>
    </p>
    <p class="text-muted mb-2">Hosted by <b><%= listing.owner ? listing.owner.username : 'Unknown Host' %></b></p>
    <hr>
    <p style="font-size:1.05rem;"><%= listing.description %></p>
    <h5 class="fw-bold mb-3" style="color: var(--accent-color);">
      &#8377;<%= listing.price.toLocaleString("en-IN") %> <small class="text-muted fw-normal fs-6">/ night</small>
    </h5>
    <hr>

    <!-- Action Buttons (Reserve & Chat) -->
    <div class="d-flex gap-3 align-items-center mb-4 mt-3">
      <% if (currUser) { %>
        <a href="/listings/<%= listing._id %>/book" class="btn reserve-btn btn-lg px-4 py-2">
          <i class="fa-solid fa-calendar-check me-2"></i> Reserve Now
        </a>
        
        <% if (listing.owner && !listing.owner._id.equals(currUser._id)) { %>
          <a href="/listings/<%= listing._id %>/chat" class="btn btn-outline-dark btn-lg px-4 py-2 rounded-pill chat-trigger-btn">
            <i class="fa-solid fa-comment-dots me-2"></i> Message Host
          </a>
        <% } %>

      <% } else { %>
        <button type="button" class="btn reserve-btn btn-lg px-4 py-2" data-bs-toggle="modal" data-bs-target="#loginModal">
          <i class="fa-solid fa-calendar-check me-2"></i> Reserve Now
        </button>
        <button type="button" class="btn btn-outline-dark btn-lg px-4 py-2 rounded-pill" data-bs-toggle="modal" data-bs-target="#loginModal">
          <i class="fa-solid fa-comment-dots me-2"></i> Message Host
        </button>
      <% } %>
    </div>

        <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
          <div class="btns mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
              <button class="btn btn-dark offset-4">Delete</button>
            </form>
          </div>

          <% } %>



            <div class="col-3 offset-3 mb-3">

              <% if(currUser) {%>
                <hr />
                <h4>Leave a Review</h4>

                <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">


                  <div class="mb-3 mt-3">
                    <label for="reting" class="form-label">Rating</label>
                    <fieldset class="starability-slot">

                      <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                        aria-label="No rating." />

                      <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                      <label for="first-rate1" title="Terrible">1 star</label>
                      <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                      <label for="first-rate2" title="Not good">2 stars</label>
                      <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                      <label for="first-rate3" title="Average">3 stars</label>
                      <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                      <label for="first-rate4" title="Very good">4 stars</label>
                      <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                      <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                  </div>
                  <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                      required></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                  </div>

                  <button class="btn btn-outline-dark">Submit</button>
                </form>
                <hr />
                <% } %>

                  <% if(listing.reviews.length> 0) {%>
                    <div class="row">
                      <p><b>All Reviews</b></p>
                      <% for(review of listing.reviews) { %>
                        <div class="card col-5 ms-3 mb-3">
                          <div class="card-body">
                            <h5 class="card-title">@<%= review.author.username%>
                            </h5>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                            <p class="card-text">
                              <%= review.comment %>
                            </p>

                          </div>
                          <!-- ✅ Delete Button -->
                          <form method="POST"
                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            class="mt-3 text-end">
                            <button class="btn btn-sm btn-dark">Delete</button>
                          </form>
                        </div>
                        <% } %>
                    </div>
                    <% } %>

            </div>

            <!-- Map Section -->
            <div class="col-8 offset-3 mb-3 map-section">
              <h3>Where you'll be</h3>
              <div id="map"></div>
            </div>

            <!-- Hidden inputs to store location data -->
            <input type="hidden" id="listingLocation" value="<%= listing.location %>">
            <input type="hidden" id="listingCountry" value="<%= listing.country %>">

            <script src="/js/map.js"></script>
            <script>
              // Wait for page to fully load before initializing map
              window.addEventListener('load', function () {
                const location = document.getElementById('listingLocation').value;
                const country = document.getElementById('listingCountry').value;
                console.log('Page loaded, initializing map...');
                initializeMap(location, country);
              });
            </script>