<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
    <div class="col-lg-10 offset-lg-1">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">My Listings Library</h3>
            <a href="/listings/new" class="btn btn-danger rounded-pill px-4">Create New</a>
        </div>

        <% if(allListings.length === 0) { %>
            <div class="text-center py-5 border rounded-3 bg-light">
                <i class="fa-solid fa-house-chimney-user mb-3" style="font-size: 4rem; color: #ccc;"></i>
                <h4>You haven't created any listings yet</h4>
                <p class="text-muted">Start by adding your property to Wanderlust!</p>
                <a href="/listings/new" class="btn btn-danger mt-2">Get Started</a>
            </div>
        <% } else { %>
            <div class="table-responsive bg-white shadow-sm rounded-4 p-3 border">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Preview</th>
                            <th scope="col">Title</th>
                            <th scope="col">Location</th>
                            <th scope="col">Price</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let listing of allListings) { %>
                            <tr>
                                <td>
                                    <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : (listing.image && listing.image.url) ? listing.image.url : 'https://placehold.co/80x60/ffe4e6/fe424d?text=No+Img' %>" class="rounded-3" style="width: 80px; height: 60px; object-fit: cover;" alt="image">
                                </td>
                                <td>
                                    <div class="fw-bold"><%= listing.title %></div>
                                    <span class="badge bg-light text-dark border">Owner: You</span>
                                </td>
                                <td><i class="fa-solid fa-location-dot text-danger small"></i> <%= listing.location %></td>
                                <td class="fw-bold text-success">&#8377; <%= listing.price.toLocaleString("en-IN") %></td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-outline-dark" title="View"><i class="fa-solid fa-eye"></i></a>
                                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Pakka delete karna hai?')" title="Delete"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
