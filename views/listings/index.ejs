   <% layout("/layouts/boilerplate") %>
<link rel="stylesheet" href="/css/index.css">
  <!-- <h3>All Listings</h3> -->
  <!-- <form method="GET" action="/listings/new">
      <button>Create New Listing</button>
    </form> -->



  <div id="filters">
    <% const currentCat = typeof category !== 'undefined' ? category : ''; %>
    
    <a href="/listings?category=Trending" class="filter <%= currentCat === 'Trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= currentCat === 'Rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter <%= currentCat === 'Iconic Cities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= currentCat === 'Mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castels" class="filter <%= currentCat === 'Castels' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fort-awesome"></i></div>
      <p>Castels</p>
    </a>
    <a href="/listings?category=Amezing Pool" class="filter <%= currentCat === 'Amezing Pool' ? 'active' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amezing Pool</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currentCat === 'Camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= currentCat === 'Farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currentCat === 'Arctic' ? 'active' : '' %>">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Domes" class="filter <%= currentCat === 'Domes' ? 'active' : '' %>">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Domes</p>
    </a>
    <a href="/listings?category=Boats" class="filter <%= currentCat === 'Boats' ? 'active' : '' %>">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
    </a>
    <a href="/listings?category=Resort" class="filter <%= currentCat === 'Resort' ? 'active' : '' %>">
      <div><i class="fa-solid fa-hotel"></i></div>
      <p>Resort</p>
    </a>

  </div>

  <!-- Clear filter option if a category is selected -->
  <% if(typeof category !== 'undefined' && category) { %>
    <div class="mb-3 d-flex justify-content-between align-items-center">
      <h5 class="m-0">Showing results for <b><%= category %></b></h5>
      <a href="/listings" class="btn btn-sm btn-outline-secondary">Clear Filter</a>
    </div>
  <% } %>

  <% if(allListings.length === 0) { %>
    <div class="alert alert-warning mt-4 text-center">
      <h4><i class="fa-solid fa-magnifying-glass"></i> No Listings Found</h4>
      <p>We couldn't find any listings in the selected category.</p>
      <a href="/listings" class="btn btn-dark mt-2">View All Listings</a>
    </div>
  <% } %>

  <!-- AIRBNB MAP TOGGLE BUTTON -->
  <button id="mapToggleBtn" class="btn btn-dark map-toggle-btn shadow-lg">
    <span class="btn-text">Show Map</span> <i class="fa-solid fa-map ms-1"></i>
  </button>


  <div id="globalMapContainer">
    <!-- Custom Floating Search Bar (Global Discovery) -->
    <div class="map-search-container collapsed" id="globalSearchContainer">
        <div class="search-main-row">
            <span class="search-toggle-icon" id="globalSearchToggle"><i class="fa-solid fa-magnifying-glass"></i></span>
            <div class="search-glass-effect-wrapper">
                <div class="input-group search-glass-effect">
                    <input type="text" id="globalSearchInput" class="form-control" placeholder="Search world destinations..." autocomplete="off">
                    <button class="btn btn-dark rounded-pill search-btn-responsive" id="globalSearchBtn">
                        <span class="btn-text">Discover</span> <i class="fa-solid fa-earth-americas icon-text"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Results Dropdown -->
        <div id="globalSearchResults" class="map-results-dropdown shadow"></div>
    </div>
    <div id="indexMap" style="width: 100%; height: 100%;"></div>
  </div>

  <div id="listViews">

  <!-- ═══ SKELETON LOADER (ghost cards) ═══ -->


    <!-- ═══ Popular Homes Horizontal Slider ═══ -->
    <% if(allListings && allListings.length > 5 && !category) { %>
      <div class="popular-section">
        <div class="popular-header">
          <h3 class="fw-bold mb-0">Popular homes</h3>
          <div class="d-flex gap-2">
            <button class="slider-nav-btn" onclick="document.getElementById('popularSlider').scrollBy({left: -320, behavior: 'smooth'})">
              <i class="fa-solid fa-chevron-left"></i>
            </button>
            <button class="slider-nav-btn" onclick="document.getElementById('popularSlider').scrollBy({left: 320, behavior: 'smooth'})">
              <i class="fa-solid fa-chevron-right"></i>
            </button>
          </div>
        </div>

        <div class="popular-slider" id="popularSlider">
          <% 
             // Sort by rating (high to low) or just take recent ones
             let popularListings = [...allListings].sort((a, b) => {
               let rA = (a.reviews && a.reviews.length > 0) ? (a.reviews.reduce((s, r) => s + r.rating, 0) / a.reviews.length) : 0;
               let rB = (b.reviews && b.reviews.length > 0) ? (b.reviews.reduce((s, r) => s + r.rating, 0) / b.reviews.length) : 0;
               return rB - rA;
             }).slice(0, 8);

             for(let listing of popularListings) { 
          %>
            <div class="popular-card">
              <a href="/listings/<%= listing._id %>" class="listing-link d-block">
                <div class="card card-listing border-0">
                  <div class="listing-img-wrapper position-relative overflow-hidden">
                    <!-- Carousel for Popular Home -->
                    <% if(listing.images && listing.images.length > 1) { %>
                      <div id="popular-carousel-<%= listing._id %>" class="carousel slide h-100 w-100" data-bs-ride="false" data-bs-interval="false">
                        <div class="carousel-indicators mb-2">
                          <% for(let i=0; i<Math.min(5, listing.images.length); i++) { %>
                            <button type="button" data-bs-target="#popular-carousel-<%= listing._id %>" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>"></button>
                          <% } %>
                        </div>
                        <div class="carousel-inner h-100 w-100">
                          <% listing.images.forEach((img, index) => { %>
                            <div class="carousel-item h-100 w-100 <%= index === 0 ? 'active' : '' %>">
                              <img src="<%= img.url.replace('/upload', '/upload/w_600,h_800,c_fill') %>" class="d-block w-100 h-100 object-fit-cover" alt="popular_listing">
                            </div>
                          <% }) %>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#popular-carousel-<%= listing._id %>" data-bs-slide="prev" onclick="event.preventDefault(); event.stopPropagation();">
                          <span class="carousel-control-prev-icon-custom"><i class="fa-solid fa-chevron-left"></i></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#popular-carousel-<%= listing._id %>" data-bs-slide="next" onclick="event.preventDefault(); event.stopPropagation();">
                          <span class="carousel-control-next-icon-custom"><i class="fa-solid fa-chevron-right"></i></span>
                        </button>
                      </div>
                    <% } else { %>
                      <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url.replace('/upload', '/upload/w_600,h_800,c_fill') : (listing.image ? listing.image.url.replace('/upload', '/upload/w_600,h_800,c_fill') : '') %>" alt="popular_listing" class="w-100 h-100 object-fit-cover" loading="lazy">
                    <% } %>

                    <div class="guest-favorite-badge">Trending</div>
                    
                    <!-- Favorite Heart Button -->
                    <% 
                      let isFav = false;
                      if(currUser && currUser.favorites) {
                         isFav = currUser.favorites.some(favId => favId.toString() === listing._id.toString());
                      }
                    %>
                    <button class="favorite-btn <%= isFav ? 'favorited' : '' %>" data-id="<%= listing._id %>" onclick="toggleFavorite(event, this)" style="top: 12px; right: 12px; font-size: 1.2rem; z-index: 10;">
                      <i class="fa-solid fa-heart"></i>
                    </button>
                  </div>
                  <div class="card-info mt-2">
                    <div class="d-flex justify-content-between align-items-center">
                      <b class="text-truncate" style="font-size: 0.95rem;"><%= listing.title %></b>
                      <span class="small"><i class="fa-solid fa-star"></i> <%= (listing.reviews && listing.reviews.length > 0) ? (listing.reviews.reduce((s, r) => s + r.rating, 0) / listing.reviews.length).toFixed(1) : "New" %></span>
                    </div>
                    <p class="text-muted small mb-1"><%= listing.location %></p>
                    <div class="price" style="font-size: 0.9rem;">
                      &#8377;<%= listing.price.toLocaleString("en-IN") %> <span class="fw-normal">night</span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% } %>
          
          <!-- "See All" Card (Stacked Images Design) -->
          <div class="popular-card d-flex align-items-center justify-content-center">
            <a href="/listings/explore" class="show-more-card text-decoration-none text-center p-5 rounded-4 border w-100 h-100 d-flex flex-column align-items-center justify-content-center">
                <div class="image-stack mb-4">
                  <% for(let j=0; j<Math.min(3, popularListings.length); j++) { 
                     let pListing = popularListings[j];
                     let imgUrl = (pListing.images && pListing.images.length > 0) ? pListing.images[0].url : (pListing.image ? pListing.image.url : '');
                  %>
                    <img src="<%= imgUrl.replace('/upload', '/upload/w_100,h_100,c_fill') %>" class="stack-img" alt="stack">
                  <% } %>
                </div>
               <h6 class="fw-bold mb-0" style="font-size: 1.1rem; color: var(--text-color);">See all</h6>
            </a>
          </div>
        </div>
      </div>
      <hr class="my-5 opacity-25">
    <% } %>

    <!-- Top Destinations Section (Dynamic from DB) -->

    <% 
       // Group listings by location to get unique cities and their counts
       const cityStats = {};
       allListings.forEach(l => {
         if(!cityStats[l.location]) {
           cityStats[l.location] = { 
             count: 0, 
             img: (l.images && l.images.length > 0) ? l.images[0].url : (l.image ? l.image.url : '') 
           };
         }
         cityStats[l.location].count++;
       });

       const cities = Object.keys(cityStats).sort((a, b) => cityStats[b].count - cityStats[a].count).slice(0, 8);
    %>

    <% if(cities.length > 0) { %>
    <div class="destinations-section mb-5 px-3">
      <div class="popular-header d-flex justify-content-between align-items-center mb-4">
        <div>
          <h4 class="fw-bold mb-1">Top Destinations</h4>
          <p class="text-muted small mb-0">Discover homes in our most active locations</p>
        </div>
        <div class="slider-controls d-flex gap-2">
          <button class="slider-nav-btn" onclick="document.getElementById('destSlider').scrollBy({left: -320, behavior: 'smooth'})">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button class="slider-nav-btn" onclick="document.getElementById('destSlider').scrollBy({left: 320, behavior: 'smooth'})">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        </div>
      </div>

      <div class="popular-slider" id="destSlider">
        <% for(let cityName of cities) { 
           // Get all images for this city to create a city carousel
           let cityListings = allListings.filter(l => l.location === cityName).slice(0, 5);
           let cityCount = cityStats[cityName].count;
        %>
          <div class="dest-card-rect">
            <div class="dest-img-rect-wrapper mb-2">
              <div id="city-carousel-<%= cityName.replace(/\s+/g, '-') %>" class="carousel slide h-100 w-100" data-bs-ride="false" data-bs-interval="false">
                <div class="carousel-inner h-100 w-100">
                  <% cityListings.forEach((l, index) => { 
                     let imgUrl = (l.images && l.images.length > 0) ? l.images[0].url : (l.image ? l.image.url : '');
                  %>
                    <div class="carousel-item h-100 w-100 <%= index === 0 ? 'active' : '' %>">
                      <img src="<%= imgUrl.replace('/upload', '/upload/w_400,h_500,c_fill') %>" class="d-block w-100 h-100 object-fit-cover" alt="<%= cityName %>">
                    </div>
                  <% }) %>
                </div>
                <% if(cityListings.length > 1) { %>
                  <button class="carousel-control-prev" type="button" data-bs-target="#city-carousel-<%= cityName.replace(/\s+/g, '-') %>" data-bs-slide="prev" onclick="event.preventDefault(); event.stopPropagation();">
                    <span class="carousel-control-prev-icon-custom"><i class="fa-solid fa-chevron-left"></i></span>
                  </button>
                  <button class="carousel-control-next" type="button" data-bs-target="#city-carousel-<%= cityName.replace(/\s+/g, '-') %>" data-bs-slide="next" onclick="event.preventDefault(); event.stopPropagation();">
                    <span class="carousel-control-next-icon-custom"><i class="fa-solid fa-chevron-right"></i></span>
                  </button>
                <% } %>
              </div>
              
              <a href="/listings?search=<%= cityName %>" class="dest-card-info-overlay text-decoration-none">
                 <h6 class="fw-bold mb-0 text-white text-shadow text-truncate"><%= cityName %></h6>
                 <p class="text-white small mb-0 opacity-75"><%= cityCount %> <%= cityCount > 1 ? 'Listings' : 'Listing' %></p>
              </a>
            </div>
          </div>
        <% } %>

        <!-- "See All" Destinations Card -->
        <div class="dest-card-rect d-flex align-items-center justify-content-center">
          <a href="/listings/destinations" class="show-more-card text-decoration-none text-center p-5 rounded-4 border w-100 h-100 d-flex flex-column align-items-center justify-content-center">
              <div class="image-stack mb-4">
                <% for(let j=0; j<Math.min(3, cities.length); j++) { 
                   let cityName = cities[j];
                   let l = allListings.find(list => list.location === cityName);
                   let imgUrl = (l && l.images && l.images.length > 0) ? l.images[0].url : (l && l.image ? l.image.url : '');
                %>
                  <img src="<%= imgUrl.replace('/upload', '/upload/w_100,h_100,c_fill') %>" class="stack-img" alt="city-stack">
                <% } %>
              </div>
              <h6 class="fw-bold mb-0" style="font-size: 1.1rem; color: var(--text-color);">See all</h6>
          </a>
        </div>
      </div>
    </div>
    <hr class="my-5 opacity-25">
    <% } %>
  <div id="skeletonGrid" class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-2 mt-3 g-4">
    <% for(let i = 0; i < 8; i++) { %>
      <div class="col">
        <div class="skeleton-card w-100">
          <div class="skeleton-img" style="aspect-ratio: 1/1; height: auto;"></div>
          <div class="skeleton-line" style="width:80%;"></div>
          <div class="skeleton-line short"></div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Real Listings (hidden at first) -->
  <div id="realListings" class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-2 mt-3 g-4">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link d-block">
          <div class="card card-listing h-100">
            <div class="listing-img-wrapper position-relative overflow-hidden rounded-4">
              <!-- Carousel for Multiple Images -->
              <% if(listing.images && listing.images.length > 1) { %>
                <div id="carousel-<%= listing._id %>" class="carousel slide h-100 w-100" data-bs-ride="false" data-bs-interval="false">
                  <!-- Indicators (Dots) -->
                  <div class="carousel-indicators mb-2">
                    <% for(let i=0; i<Math.min(5, listing.images.length); i++) { %>
                      <button type="button" data-bs-target="#carousel-<%= listing._id %>" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>" aria-label="Slide <%= i + 1 %>"></button>
                    <% } %>
                  </div>

                  <div class="carousel-inner h-100 w-100">
                    <% listing.images.forEach((img, index) => { %>
                      <div class="carousel-item h-100 w-100 <%= index === 0 ? 'active' : '' %>">
                        <img src="<%= img.url.replace('/upload', '/upload/w_600,h_600,c_fill') %>" class="d-block w-100 h-100 object-fit-cover" alt="listing_img">
                      </div>
                    <% }) %>
                  </div>

                  <!-- Navigation Arrows -->
                  <button class="carousel-control-prev" type="button" data-bs-target="#carousel-<%= listing._id %>" data-bs-slide="prev" onclick="event.preventDefault(); event.stopPropagation();">
                    <span class="carousel-control-prev-icon-custom" aria-hidden="true"><i class="fa-solid fa-chevron-left"></i></span>
                  </button>
                  <button class="carousel-control-next" type="button" data-bs-target="#carousel-<%= listing._id %>" data-bs-slide="next" onclick="event.preventDefault(); event.stopPropagation();">
                    <span class="carousel-control-next-icon-custom" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
                  </button>
                </div>
              <% } else { %>
                <!-- Single Image fallback -->
                <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url.replace('/upload', '/upload/w_600,h_600,c_fill') : (listing.image ? listing.image.url.replace('/upload', '/upload/w_600,h_600,c_fill') : 'https://placehold.co/600x600/ffe4e6/fe424d?text=No+Image') %>" class="w-100 h-100 object-fit-cover" alt="listing_img">
              <% } %>
              
              <!-- Guest Favourite Badge -->
              <% if(listing.price > 2500) { %>
                <div class="guest-favorite-badge">Guest favourite</div>
              <% } %>
              
              <!-- Favorite Heart Button -->
              <% 
                let isFav = false;
                if(currUser && currUser.favorites) {
                   isFav = currUser.favorites.some(favId => favId.toString() === listing._id.toString());
                }
              %>
              <button class="favorite-btn <%= isFav ? 'favorited' : '' %>" data-id="<%= listing._id %>" onclick="toggleFavorite(event, this)" aria-label="Save to favorites">
                <i class="fa-solid fa-heart"></i>
              </button>
            </div>
            
            <div class="card-info">
              <% 
                let avgRating = "New";
                if(listing.reviews && listing.reviews.length > 0) {
                   let total = listing.reviews.reduce((sum, r) => sum + r.rating, 0);
                   avgRating = (total / listing.reviews.length).toFixed(1);
                }
              %>
              <div class="d-flex justify-content-between align-items-start mt-1">
                <b class="text-truncate pe-2"><%= listing.location %>, <%= listing.country %></b>
                <span style="font-size: 0.95rem; color: var(--text-color); white-space: nowrap;">
                  <i class="fa-solid fa-star" style="font-size: 0.85rem; margin-right: 2px;"></i><%= avgRating %>
                </span>
              </div>
              <span class="text-muted"><%= listing.title %></span>
              <div class="price">
                &#8377;<%= listing.price.toLocaleString("en-IN") %> <span class="fw-normal">night</span>
                <% if(listing.taxRate && listing.taxRate > 0) { %>
                  <span class="tax-info" style="font-size:0.85rem; color:#717171; font-weight:normal;">&nbsp;+<%= listing.taxRate %>% Tax</span>
                <% } %>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <script>
    // Toggle Favorite Functionality via AJAX
    async function toggleFavorite(event, btn) {
      event.preventDefault(); // Prevent link navigation
      event.stopPropagation(); // Stop event bubbling
      
      const listingId = btn.dataset.id;
      
      try {
        const response = await fetch(`/listings/${listingId}/favorite`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (response.status === 401) {
          // Trigger Login Modal if not authenticated
          const loginModal = new bootstrap.Modal(document.getElementById('loginModal'));
          loginModal.show();
          return;
        }
        
        if (data.success) {
          // Toggle UI state
          if (data.isFavorited) {
            btn.classList.add('favorited');
          } else {
            btn.classList.remove('favorited');
          }
        }
      } catch (err) {
        console.error('Error toggling favorite:', err);
      }
    }
  </script>

  <script>
    // Skeleton → real content
    window.addEventListener('DOMContentLoaded', function() {
      const skeleton = document.getElementById('skeletonGrid');
      const real = document.getElementById('realListings');
      setTimeout(function() { skeleton.style.display = 'none'; real.classList.add('loaded'); }, 700);

      // Intersection Observer for all "See all" card animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
          }
        });
      }, { threshold: 0.5 });

      const imageStacks = document.querySelectorAll('.image-stack');
      imageStacks.forEach(stack => observer.observe(stack));
    });

  </script>

  <!-- Pass MongoDB Listings cleanly to Frontend JS -->
  <script type="application/json" id="wanderlust-listings-data">
    <%- JSON.stringify(allListings).replace(/</g, '\\u003c') %>
  </script>
  <script>
    window.WANDERLUST_LISTINGS = JSON.parse(document.getElementById('wanderlust-listings-data').textContent);
  </script>
  
  <!-- Actual Global Map Script (Must load at the end) -->
  <script src="/js/indexMap.js"></script>

  </div> <!-- Closed ListView Container -->