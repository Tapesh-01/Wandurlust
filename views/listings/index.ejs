<% layout("/layouts/boilerplate") %>
  <!-- <h3>All Listings</h3> -->
  <!-- <form method="GET" action="/listings/new">
      <button>Create New Listing</button>
    </form> -->

  <style>
    /* ── Category Filters ── */
    #filters { display: flex; flex-wrap: wrap; align-items: center; }
    .filter { text-align: center; margin-right: 2rem; margin-top: 2rem; opacity: 0.7; text-decoration: none; color: var(--text-color); }
    .filter:hover, .filter.active { opacity: 1; cursor: pointer; color: #fe424d; }
    .filter.active { border-bottom: 2px solid #fe424d; padding-bottom: 5px; }
    .filter p { font-size: 0.8rem; }
    .tax-info { display: none; }
    .tax-toggle { border: 1px solid var(--border-color); border-radius: 1rem; height: 3.25rem; padding: 1rem; display: flex; align-items: center; margin-left: 2rem; color: var(--text-color); }
  </style>

  <div id="filters">
    <% const currentCat = typeof category !== 'undefined' ? category : ''; %>
    
    <a href="/listings?category=Trending" class="filter <%= currentCat === 'Trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= currentCat === 'Rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter <%= currentCat === 'Iconic Cities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= currentCat === 'Mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castels" class="filter <%= currentCat === 'Castels' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fort-awesome"></i></div>
      <p>Castels</p>
    </a>
    <a href="/listings?category=Amezing Pool" class="filter <%= currentCat === 'Amezing Pool' ? 'active' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amezing Pool</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currentCat === 'Camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= currentCat === 'Farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currentCat === 'Arctic' ? 'active' : '' %>">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Domes" class="filter <%= currentCat === 'Domes' ? 'active' : '' %>">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Domes</p>
    </a>
    <a href="/listings?category=Boats" class="filter <%= currentCat === 'Boats' ? 'active' : '' %>">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
    </a>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">
          Display total after taxes
        </label>
      </div>
    </div>
  </div>

  <!-- Clear filter option if a category is selected -->
  <% if(typeof category !== 'undefined' && category) { %>
    <div class="mb-3 d-flex justify-content-between align-items-center">
      <h5 class="m-0">Showing results for <b><%= category %></b></h5>
      <a href="/listings" class="btn btn-sm btn-outline-secondary">Clear Filter</a>
    </div>
  <% } %>

  <% if(allListings.length === 0) { %>
    <div class="alert alert-warning mt-4 text-center">
      <h4><i class="fa-solid fa-magnifying-glass"></i> No Listings Found</h4>
      <p>We couldn't find any listings in the selected category.</p>
      <a href="/listings" class="btn btn-dark mt-2">View All Listings</a>
    </div>
  <% } %>

  <!-- AIRBNB MAP TOGGLE BUTTON -->
  <button id="mapToggleBtn" class="btn btn-dark map-toggle-btn shadow-lg">
    <span class="btn-text">Show Map</span> <i class="fa-solid fa-map ms-1"></i>
  </button>


  <style>
    /* ── Map Toggle Button ── */
    .map-toggle-btn { position: fixed; bottom: 60px; left: 50%; transform: translateX(-50%); z-index: 1000; border-radius: 30px; padding: 12px 24px; font-weight: 600; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease; }
    .map-toggle-btn:hover { transform: translateX(-50%) scale(1.05); background-color: var(--primary-color) !important; border-color: var(--primary-color) !important; }
    /* ── Global Map Container ── */
    #globalMapContainer { display: none; height: calc(100vh - 160px); width: 100%; border-radius: 12px; overflow: hidden; margin-top: 20px; margin-bottom: 80px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); position: relative; }
    #listViews { width: 100%; }
    /* ── Map Floating Search ── */
    .map-search-container { position: absolute; top: 25px; left: 50%; transform: translateX(-50%); z-index: 1000; width: 50px; height: 50px; transition: 0.4s cubic-bezier(0.19, 1, 0.22, 1); border-radius: 50px; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.25); display: flex; flex-direction: column; padding: 4px; border: 2px solid white; overflow: visible; }
    .map-search-container.collapsed { cursor: pointer; overflow: hidden; }
    .map-search-container.expanded { width: 90%; max-width: 440px; height: auto; min-height: 50px; border-radius: 25px; }
    .search-main-row { display: flex; align-items: center; width: 100%; height: 42px; }
    .search-toggle-icon { width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; background-color: #fe424d !important; color: white !important; border-radius: 50%; font-size: 1.1rem; flex-shrink: 0; transition: 0.3s; cursor: pointer; }
    .search-glass-effect-wrapper { flex-grow: 1; display: none; opacity: 0; padding-left: 10px; }
    .map-search-container.expanded .search-glass-effect-wrapper { display: block; opacity: 1; }
    .map-results-dropdown { width: 100%; background: white; border-radius: 12px; margin-top: 8px; max-height: 250px; overflow-y: auto; display: none; border: 1px solid #eee; z-index: 1001; flex-basis: 100%; }
    .search-glass-effect { background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-radius: 50px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); border: 1px solid rgba(255,255,255,0.3); overflow: hidden; display: flex !important; width: 100%; }
    .map-result-item { padding: 12px 18px; cursor: pointer; border-bottom: 1px solid #f8f9fa; transition: 0.2s; display: flex; align-items: flex-start; gap: 12px; }
    .map-result-item:hover { background: #f7f7f7; }
    .map-result-item .icon { color: #fe424d; margin-top: 3px; }
    .map-result-item .text-main { font-weight: 600; font-size: 0.85rem; display: block; color: #222; }
    .map-result-item .text-sub { font-size: 0.75rem; color: #717171; }
  </style>
  <div id="globalMapContainer">
    <!-- Custom Floating Search Bar (Global Discovery) -->
    <div class="map-search-container collapsed" id="globalSearchContainer">
        <div class="search-main-row">
            <span class="search-toggle-icon" id="globalSearchToggle"><i class="fa-solid fa-magnifying-glass"></i></span>
            <div class="search-glass-effect-wrapper">
                <div class="input-group search-glass-effect">
                    <input type="text" id="globalSearchInput" class="form-control" placeholder="Search world destinations..." autocomplete="off">
                    <button class="btn btn-dark rounded-pill search-btn-responsive" id="globalSearchBtn">
                        <span class="btn-text">Discover</span> <i class="fa-solid fa-earth-americas icon-text"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Results Dropdown -->
        <div id="globalSearchResults" class="map-results-dropdown shadow"></div>
    </div>
    <div id="indexMap" style="width: 100%; height: 100%;"></div>
  </div>

  <div id="listViews">

  <!-- ═══ SKELETON LOADER (ghost cards) ═══ -->
  <style>
    @keyframes shimmer { 0% { background-position: -700px 0; } 100% { background-position: 700px 0; } }
    .skeleton-card { width: 20rem; border-radius: 1rem; overflow: hidden; margin-bottom: 2rem; }
    .skeleton-img { height: 20rem; border-radius: 1rem; background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%); background-size: 700px 100%; animation: shimmer 1.4s infinite linear; }
    .skeleton-line { height: 14px; border-radius: 6px; margin-top: 10px; background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%); background-size: 700px 100%; animation: shimmer 1.4s infinite linear; }
    .skeleton-line.short { width: 55%; }
    [data-theme="dark"] .skeleton-img, [data-theme="dark"] .skeleton-line { background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%); background-size: 700px 100%; }
    #realListings { opacity: 0; transition: opacity 0.5s ease; }
    #realListings.loaded { opacity: 1; }
  </style>

  <style>
    /* Premium Airbnb Card Styles */
    .card-listing { border: none !important; background: transparent !important; cursor: pointer; }
    .listing-img-wrapper {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      aspect-ratio: 1 / 1;
      margin-bottom: 12px;
      isolation: isolate;
    }
    .listing-img-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }
    .card-listing:hover .listing-img-wrapper img { transform: scale(1.05); }
    
    .guest-favorite-badge {
      position: absolute;
      top: 12px; left: 12px;
      background: rgba(255, 255, 255, 0.95);
      color: #222;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      z-index: 10;
    }
    
    .favorite-btn {
      position: absolute;
      top: 12px; right: 12px;
      background: transparent;
      border: none;
      font-size: 1.5rem;
      color: rgba(0,0,0,0.5);
      cursor: pointer;
      z-index: 10;
      transition: transform 0.1s, color 0.2s;
      /* Outline effect using stroke */
      -webkit-text-stroke: 2px white;
    }
    .favorite-btn:hover { transform: scale(1.1); }
    .favorite-btn:active { transform: scale(0.9); }
    .favorite-btn.favorited {
      color: #fe424d;
      -webkit-text-stroke: 0px white;
    }
    
    .card-info { padding: 0 4px; }
    .card-info b { font-size: 1rem; color: var(--text-color); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-info .text-muted { font-size: 0.95rem; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-info .price { font-weight: 600; color: var(--text-color); margin-top: 6px; font-size: 1rem; }
    
    [data-theme="dark"] .guest-favorite-badge { background: rgba(30, 41, 59, 0.95); color: #f1f5f9; }
    /* Fix for dark mode specificity overriding transparent background */
    [data-theme="dark"] .card.card-listing { border: none !important; background: transparent !important; }
  </style>

  <!-- Ghost Cards -->
  <div id="skeletonGrid" class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 mt-3 g-4">
    <% for(let i = 0; i < 8; i++) { %>
      <div class="col">
        <div class="skeleton-card w-100">
          <div class="skeleton-img" style="aspect-ratio: 1/1; height: auto;"></div>
          <div class="skeleton-line" style="width:80%;"></div>
          <div class="skeleton-line short"></div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Real Listings (hidden at first) -->
  <div id="realListings" class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 mt-3 g-4">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link d-block">
          <div class="card card-listing h-100">
            <div class="listing-img-wrapper">
              
              <!-- Guest Favourite Badge (Logic: showing for highly priced or specific listings as demo) -->
              <% if(listing.price > 2500) { %>
                <div class="guest-favorite-badge">Guest favourite</div>
              <% } %>
              
              <!-- Favorite Heart Button -->
              <% 
                let isFav = false;
                if(currUser && currUser.favorites) {
                   isFav = currUser.favorites.some(favId => favId.toString() === listing._id.toString());
                }
              %>
              <button class="favorite-btn <%= isFav ? 'favorited' : '' %>" data-id="<%= listing._id %>" onclick="toggleFavorite(event, this)" aria-label="Save to favorites">
                <i class="fa-solid fa-heart"></i>
              </button>

              <img 
                src="<%= 
                  (listing.images && listing.images.length > 0) 
                    ? listing.images[0].url.replace('/upload', '/upload/w_600,h_600,c_fill')
                    : (listing.image && listing.image.url) 
                      ? listing.image.url.replace('/upload', '/upload/w_600,h_600,c_fill')
                      : 'https://placehold.co/600x600/ffe4e6/fe424d?text=No+Image'
                %>" 
                alt="listing_image" loading="lazy" />
            </div>
            
            <div class="card-info">
              <% 
                let avgRating = "New";
                if(listing.reviews && listing.reviews.length > 0) {
                   let total = listing.reviews.reduce((sum, r) => sum + r.rating, 0);
                   avgRating = (total / listing.reviews.length).toFixed(1);
                }
              %>
              <div class="d-flex justify-content-between align-items-center">
                <b><%= listing.location %>, <%= listing.country %></b>
                <span style="font-size: 0.9rem;"><i class="fa-solid fa-star"></i> <%= avgRating %></span>
              </div>
              <span class="text-muted"><%= listing.title %></span>
              <div class="price">
                &#8377;<%= listing.price.toLocaleString("en-IN") %> <span class="fw-normal">night</span>
                <span class="tax-info" style="display:none; font-size:0.85rem; color:#717171; font-weight:normal;">&nbsp;+18% GST</span>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>

  <script>
    // Toggle Favorite Functionality via AJAX
    async function toggleFavorite(event, btn) {
      event.preventDefault(); // Prevent link navigation
      event.stopPropagation(); // Stop event bubbling
      
      const listingId = btn.dataset.id;
      
      try {
        const response = await fetch(`/listings/${listingId}/favorite`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (response.status === 401) {
          // Trigger Login Modal if not authenticated
          const loginModal = new bootstrap.Modal(document.getElementById('loginModal'));
          loginModal.show();
          return;
        }
        
        if (data.success) {
          // Toggle UI state
          if (data.isFavorited) {
            btn.classList.add('favorited');
          } else {
            btn.classList.remove('favorited');
          }
        }
      } catch (err) {
        console.error('Error toggling favorite:', err);
      }
    }
  </script>

  <script>
    // Skeleton → real content
    window.addEventListener('DOMContentLoaded', function() {
      const skeleton = document.getElementById('skeletonGrid');
      const real = document.getElementById('realListings');
      setTimeout(function() { skeleton.style.display = 'none'; real.classList.add('loaded'); }, 700);
    });
    // Tax toggle
    let taxSwitch = document.getElementById("switchCheckDefault");
    if(taxSwitch) {
      taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (let info of taxInfo) { info.style.display = (info.style.display != "inline") ? "inline" : "none"; }
      });
    }
  </script>

  <!-- Pass MongoDB Listings cleanly to Frontend JS -->
  <script type="application/json" id="wanderlust-listings-data">
    <%- JSON.stringify(allListings).replace(/</g, '\\u003c') %>
  </script>
  <script>
    window.WANDERLUST_LISTINGS = JSON.parse(document.getElementById('wanderlust-listings-data').textContent);
  </script>
  
  <!-- Actual Global Map Script (Must load at the end) -->
  <script src="/js/indexMap.js"></script>

  </div> <!-- Closed ListView Container -->