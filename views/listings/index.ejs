<% layout("/layouts/boilerplate") %>
  <!-- <h3>All Listings</h3> -->
  <!-- <form method="GET" action="/listings/new">
      <button>Create New Listing</button>
    </form> -->

  <style>
    #filters {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
    }

    .filter {
      text-align: center;
      margin-right: 2rem;
      margin-top: 2rem;
      opacity: 0.7;
      text-decoration: none;
      color: inherit;
    }

    .filter:hover, .filter.active {
      opacity: 1;
      cursor: pointer;
      color: #fe424d;
    }
    
    .filter.active {
      border-bottom: 2px solid #fe424d;
      padding-bottom: 5px;
    }

    .filter p {
      font-size: 0.8rem;
    }

    .tax-info {
      display: none;
    }

    .tax-toggle {
      border: 1px solid var(--border-color);
      border-radius: 1rem;
      height: 3.25rem;
      padding: 1rem;
      display: flex;
      align-items: center;
      margin-left: 2rem;
      color: var(--text-color);
    }
    
    .filter {
      color: var(--text-color);
    }
  </style>

  <div id="filters">
    <% const currentCat = typeof category !== 'undefined' ? category : ''; %>
    
    <a href="/listings?category=Trending" class="filter <%= currentCat === 'Trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= currentCat === 'Rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities" class="filter <%= currentCat === 'Iconic Cities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= currentCat === 'Mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castels" class="filter <%= currentCat === 'Castels' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fort-awesome"></i></div>
      <p>Castels</p>
    </a>
    <a href="/listings?category=Amezing Pool" class="filter <%= currentCat === 'Amezing Pool' ? 'active' : '' %>">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amezing Pool</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currentCat === 'Camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= currentCat === 'Farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currentCat === 'Arctic' ? 'active' : '' %>">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Domes" class="filter <%= currentCat === 'Domes' ? 'active' : '' %>">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Domes</p>
    </a>
    <a href="/listings?category=Boats" class="filter <%= currentCat === 'Boats' ? 'active' : '' %>">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
    </a>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">
          Display total after taxes
        </label>
      </div>
    </div>
  </div>

  <!-- Clear filter option if a category is selected -->
  <% if(typeof category !== 'undefined' && category) { %>
    <div class="mb-3 d-flex justify-content-between align-items-center">
      <h5 class="m-0">Showing results for <b><%= category %></b></h5>
      <a href="/listings" class="btn btn-sm btn-outline-secondary">Clear Filter</a>
    </div>
  <% } %>

  <% if(allListings.length === 0) { %>
    <div class="alert alert-warning mt-4 text-center">
      <h4><i class="fa-solid fa-magnifying-glass"></i> No Listings Found</h4>
      <p>We couldn't find any listings in the selected category.</p>
      <a href="/listings" class="btn btn-dark mt-2">View All Listings</a>
    </div>
  <% } %>

  <!-- AIRBNB MAP TOGGLE BUTTON -->
  <button id="mapToggleBtn" class="btn btn-dark map-toggle-btn shadow-lg">
    <span class="btn-text">Show Map</span> <i class="fa-solid fa-map ms-1"></i>
  </button>

  <style>
    .map-toggle-btn {
      position: fixed;
      bottom: 60px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      border-radius: 30px;
      padding: 12px 24px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s ease;
    }
    .map-toggle-btn:hover {
      transform: translateX(-50%) scale(1.05);
      background-color: var(--primary-color) !important;
      border-color: var(--primary-color) !important;
    }

    #globalMapContainer {
      display: none; /* hidden by default */
      height: calc(100vh - 160px); /* Fill screen minus navbar/footer */
      width: 100%;
      border-radius: 12px;
      overflow: hidden;
      margin-top: 20px;
      margin-bottom: 80px; /* space for toggle button */
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      position: relative;
    }

    /* Container for standard card views so we can hide them together */
    #listViews {
      width: 100%;
    }

    .map-search-container {
      position: absolute;
      top: 25px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1000;
      width: 50px;
      height: 50px;
      transition: 0.4s cubic-bezier(0.19, 1, 0.22, 1);
      border-radius: 50px;
      background: white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.25);
      display: flex;
      flex-direction: column;
      padding: 4px;
      border: 2px solid white;
      overflow: visible;
    }
    .map-search-container.collapsed {
      cursor: pointer;
      overflow: hidden;
    }
    .map-search-container.expanded {
      width: 90%;
      max-width: 440px;
      height: auto;
      min-height: 50px;
      border-radius: 25px;
    }
    .search-main-row {
      display: flex;
      align-items: center;
      width: 100%;
      height: 42px;
    }
    .search-toggle-icon {
      width: 42px;
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #fe424d !important;
      color: white !important;
      border-radius: 50%;
      font-size: 1.1rem;
      flex-shrink: 0;
      transition: 0.3s;
      cursor: pointer;
    }
    .search-glass-effect-wrapper { 
      flex-grow: 1; 
      display: none; 
      opacity: 0; 
      padding-left: 10px;
    }
    .map-search-container.expanded .search-glass-effect-wrapper { 
      display: block; 
      opacity: 1; 
    }
    .map-results-dropdown {
      width: 100%;
      background: white;
      border-radius: 12px;
      margin-top: 8px;
      max-height: 250px;
      overflow-y: auto;
      display: none;
      border: 1px solid #eee;
      z-index: 1001;
      flex-basis: 100%; /* Force it below the search bar row */
    }
    .search-glass-effect {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 50px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      border: 1px solid rgba(255,255,255,0.3);
      overflow: hidden;
      display: flex !important;
      width: 100%;
    }
    .map-result-item {
      padding: 12px 18px;
      cursor: pointer;
      border-bottom: 1px solid #f8f9fa;
      transition: 0.2s;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .map-result-item:hover { background: #f7f7f7; }
    .map-result-item .icon { color: #fe424d; margin-top: 3px; }
    .map-result-item .text-main { font-weight: 600; font-size: 0.85rem; display: block; color: #222; }
    .map-result-item .text-sub { font-size: 0.75rem; color: #717171; }
  </style>

  <!-- MAP VIEW -->
  <div id="globalMapContainer">
    <!-- Custom Floating Search Bar (Global Discovery) -->
    <div class="map-search-container collapsed" id="globalSearchContainer">
        <div class="search-main-row">
            <span class="search-toggle-icon" id="globalSearchToggle"><i class="fa-solid fa-magnifying-glass"></i></span>
            <div class="search-glass-effect-wrapper">
                <div class="input-group search-glass-effect">
                    <input type="text" id="globalSearchInput" class="form-control" placeholder="Search world destinations..." autocomplete="off">
                    <button class="btn btn-dark rounded-pill search-btn-responsive" id="globalSearchBtn">
                        <span class="btn-text">Discover</span> <i class="fa-solid fa-earth-americas icon-text"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Results Dropdown -->
        <div id="globalSearchResults" class="map-results-dropdown shadow"></div>
    </div>
    <div id="indexMap" style="width: 100%; height: 100%;"></div>
  </div>

  <div id="listViews">

  <!-- ═══ SKELETON LOADER (ghost cards) ═══ -->
  <style>
    @keyframes shimmer {
      0% { background-position: -700px 0; }
      100% { background-position: 700px 0; }
    }
    .skeleton-card {
      width: 20rem;
      border-radius: 1rem;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .skeleton-img {
      height: 20rem;
      border-radius: 1rem;
      background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
      background-size: 700px 100%;
      animation: shimmer 1.4s infinite linear;
    }
    .skeleton-line {
      height: 14px;
      border-radius: 6px;
      margin-top: 10px;
      background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
      background-size: 700px 100%;
      animation: shimmer 1.4s infinite linear;
    }
    .skeleton-line.short { width: 55%; }
    [data-theme="dark"] .skeleton-img,
    [data-theme="dark"] .skeleton-line {
      background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
      background-size: 700px 100%;
    }
    /* Real cards hidden initially, then fade in */
    #realListings { opacity: 0; transition: opacity 0.5s ease; }
    #realListings.loaded { opacity: 1; }
  </style>

  <!-- Ghost Cards -->
  <div id="skeletonGrid" class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let i = 0; i < 6; i++) { %>
      <div class="col">
        <div class="skeleton-card">
          <div class="skeleton-img"></div>
          <div class="skeleton-line" style="width:80%;"></div>
          <div class="skeleton-line short"></div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Real Listings (hidden at first) -->
  <div id="realListings" class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col card-listing" style="width: 20rem;">
          <img 
            src="<%= 
              (listing.images && listing.images.length > 0) 
                ? listing.images[0].url 
                : (listing.image && listing.image.url) 
                  ? listing.image.url 
                  : 'https://placehold.co/400x300/ffe4e6/fe424d?text=No+Image'
            %>" 
            class="card-img-top" 
            alt="listing_image" 
            style="height: 20rem" />
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b>
              <br>
              &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            </p>
            <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
          </div>
        </div>
      </a>
    <% } %>
  </div>

  <script>
    // Simulate skeleton → real content transition
    window.addEventListener('DOMContentLoaded', function() {
      const skeleton = document.getElementById('skeletonGrid');
      const real = document.getElementById('realListings');

      // Give images time to start loading, then reveal
      setTimeout(function() {
        skeleton.style.display = 'none';
        real.classList.add('loaded');
      }, 700);
    });

    // Tax toggle
    let taxSwitch = document.getElementById("switchCheckDefault");
    if(taxSwitch) {
      taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (info of taxInfo) {
          info.style.display = (info.style.display != "inline") ? "inline" : "none";
        }
      });
    }
  </script>

  <!-- Pass MongoDB Listings cleanly to Frontend JS -->
  <script>
    window.WANDERLUST_LISTINGS = <%- JSON.stringify(allListings).replace(/</g, '\\u003c') %>;
  </script>
  
  <!-- Actual Global Map Script (Must load at the end) -->
  <script src="/js/indexMap.js"></script>

  </div> <!-- Closed ListView Container -->