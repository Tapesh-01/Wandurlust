<% layout("/layouts/explore-layout") %>

<div class="explore-wrapper">
  <!-- Left Side: Scrollable List -->
  <div class="list-side" id="listingsList">
    <div class="mb-4 d-flex justify-content-between align-items-center px-2">
      <div>
        <h5 class="fw-bold mb-0">Over <%= allListings.length %> homes</h5>
        <p class="text-muted small mb-0">Discover the best stays for your next trip</p>
      </div>
      <button class="btn border rounded-pill px-3 py-2 d-flex align-items-center gap-2 bg-white shadow-sm hover-shadow" data-bs-toggle="modal" data-bs-target="#filtersModal" style="font-size: 0.85rem; font-weight: 600;">
        <i class="fa-solid fa-sliders"></i> Filters
      </button>
    </div>

    <!-- Filters Modal -->
    <div class="modal fade" id="filtersModal" tabindex="-1" aria-labelledby="filtersModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
          <div class="modal-header border-bottom px-4">
            <h5 class="modal-title fw-bold" id="filtersModalLabel">Filters</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form action="/listings/explore" method="GET">
            <div class="modal-body px-4 py-4">
              <!-- Price Range Section -->
              <h6 class="fw-bold mb-3">Price range</h6>
              <p class="text-muted small">Nightly prices before fees and taxes</p>
              <div class="d-flex gap-3 align-items-center mb-4">
                <div class="flex-grow-1">
                  <label class="small text-muted mb-1">Minimum</label>
                  <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">₹</span>
                    <input type="number" name="minPrice" class="form-control border-start-0 ps-0" placeholder="500" value="<%= filters ? filters.minPrice : '' %>">
                  </div>
                </div>
                <div class="text-muted mt-3">—</div>
                <div class="flex-grow-1">
                  <label class="small text-muted mb-1">Maximum</label>
                  <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0">₹</span>
                    <input type="number" name="maxPrice" class="form-control border-start-0 ps-0" placeholder="50,000" value="<%= filters ? filters.maxPrice : '' %>">
                  </div>
                </div>
              </div>

              <hr class="my-4 opacity-10">

              <!-- Category Section -->
              <h6 class="fw-bold mb-3">Property category</h6>
              <div class="row row-cols-3 g-2">
                <% 
                   const categories = ['All', 'Trending', 'Rooms', 'Mountains', 'Castels', 'Amezing Pool', 'Camping', 'Farms', 'Boats', 'Resort'];
                   for(let cat of categories) {
                %>
                  <div class="col">
                    <input type="radio" class="btn-check" name="category" id="cat-<%= cat %>" value="<%= cat %>" <%= (filters && filters.category === cat) || (!filters && cat === 'All') ? 'checked' : '' %>>
                    <label class="btn btn-outline-dark w-100 rounded-pill py-2" style="font-size: 0.75rem;" for="cat-<%= cat %>"><%= cat %></label>
                  </div>
                <% } %>
              </div>
            </div>
            <div class="modal-footer border-top px-4 py-3 d-flex justify-content-between">
              <a href="/listings/explore" class="text-dark fw-bold text-decoration-underline small">Clear all</a>
              <button type="submit" class="btn btn-dark px-4 py-2 rounded-3 fw-bold">Show listings</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="row row-cols-1 row-cols-xl-2 g-4 px-2">
      <% for(let listing of allListings) { %>
        <div class="col">
          <div class="explore-card h-100" onmouseenter="highlightMarker('<%= listing._id %>')" onmouseleave="unhighlightMarker('<%= listing._id %>')">
            <div class="listing-img-wrapper position-relative mb-2">
               <!-- Guest Favourite Badge -->
               <% if(listing.price > 2500) { %>
                  <div class="guest-favorite-badge" style="top:12px; left:12px; font-size: 0.7rem; padding: 4px 10px;">
                    <i class="fa-solid fa-trophy me-1" style="color: #FFD700;"></i> Guest favourite
                  </div>
               <% } %>

               <!-- Favorite Heart Button -->
               <% 
                 let isFav = false;
                 if(currUser && currUser.favorites) {
                    isFav = currUser.favorites.some(favId => favId.toString() === listing._id.toString());
                 }
               %>
               <button class="favorite-btn <%= isFav ? 'favorited' : '' %>" data-id="<%= listing._id %>" onclick="toggleFavorite(event, this)" style="top: 12px; right: 12px; font-size: 1.2rem;">
                 <i class="fa-solid fa-heart"></i>
               </button>

               <a href="/listings/<%= listing._id %>" class="d-block h-100 w-100">
                  <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url.replace('/upload', '/upload/w_600,h_400,c_fill') : (listing.image ? listing.image.url.replace('/upload', '/upload/w_600,h_400,c_fill') : '') %>" class="w-100 h-100 object-fit-cover" alt="listing_img" loading="lazy">
               </a>
            </div>

            <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark d-block">
              <div class="card-info">
                 <div class="d-flex justify-content-between align-items-start">
                    <b class="text-truncate" style="font-size: 1rem;"><%= listing.location %>, <%= listing.country %></b>
                    <span class="small"><i class="fa-solid fa-star"></i> <%= (listing.reviews && listing.reviews.length > 0) ? (listing.reviews.reduce((s, r) => s + r.rating, 0) / listing.reviews.length).toFixed(1) : "New" %></span>
                 </div>
                 <p class="text-muted small mb-1 text-truncate"><%= listing.title %></p>
                 <p class="text-muted small mb-2">Available 8-10 May</p>
                 <div class="price fw-bold" style="font-size: 0.95rem;">
                   &#8377;<%= listing.price.toLocaleString("en-IN") %> <span class="fw-normal">night</span>
                 </div>
              </div>
            </a>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right Side: Fixed Map -->
  <div class="map-side">
    <div id="exploreMap"></div>
  </div>
</div>

<script>
  // Favorite Toggle Logic
  async function toggleFavorite(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const listingId = btn.getAttribute("data-id");
    try {
      const res = await fetch(`/listings/${listingId}/favorite`, { method: "POST" });
      const data = await res.json();
      if (data.success) {
        btn.classList.toggle("favorited");
        // Optional: show a small toast or animation
      } else if (data.redirect) {
        window.location.href = data.redirect;
      }
    } catch (err) {
      console.error("Favorite toggle failed", err);
    }
  }

  // Data for Map
  const listings = <%- JSON.stringify(allListings) %>;
  let map;
  let markers = {};

  function initExploreMap() {
    // Initial Center (average of all locations or default)
    const center = [20.5937, 78.9629]; // India Center
    
    map = L.map('exploreMap', {
      zoomControl: false,
      attributionControl: false
    }).setView(center, 5);

    // Restore Standard OpenStreetMap tiles to match other maps
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    
    L.control.zoom({ position: 'bottomright' }).addTo(map);

    const bounds = L.latLngBounds();
    listings.forEach(listing => {
      if (listing.geometry && listing.geometry.coordinates && (listing.geometry.coordinates[0] !== 0 || listing.geometry.coordinates[1] !== 0)) {
        const [lng, lat] = listing.geometry.coordinates;
        
        const priceIcon = L.divIcon({
          className: 'price-marker-container',
          html: `<div class="price-marker" id="marker-${listing._id}">₹${listing.price.toLocaleString("en-IN")}</div>`,
          iconSize: [60, 36],
          iconAnchor: [30, 36] // Points exactly to the tip of the pointer
        });

        const marker = L.marker([lat, lng], { icon: priceIcon }).addTo(map);
        
        // Premium Popup Design
        const popupContent = `
          <div class="map-popup-card" style="width: 200px; overflow: hidden; border-radius: 12px;">
            <div style="height: 120px; overflow: hidden; position: relative;">
               <img src="${(listing.images && listing.images.length > 0) ? listing.images[0].url.replace('/upload', '/upload/w_400,h_300,c_fill') : (listing.image ? listing.image.url : '')}" 
                    style="width: 100%; height: 100%; object-fit: cover;" alt="img">
            </div>
            <div style="padding: 12px; font-family: 'Plus Jakarta Sans', sans-serif;">
               <div style="font-weight: 700; font-size: 0.95rem; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${listing.title}</div>
               <div style="color: #222; font-weight: 800; font-size: 0.9rem;">₹${listing.price.toLocaleString("en-IN")} <span style="font-weight: 400; color: #717171;">night</span></div>
               <a href="/listings/${listing._id}" class="btn btn-dark w-100 mt-2 py-2" style="font-size: 0.75rem; border-radius: 8px; font-weight: 600;">View Listing</a>
            </div>
          </div>
        `;
        
        marker.bindPopup(popupContent, {
           closeButton: false,
           offset: L.point(0, -30)
        });

        markers[listing._id] = marker;
        bounds.extend([lat, lng]);
      }
    });

    if (listings.length > 0) {
      map.fitBounds(bounds, { padding: [50, 50] });
    }
  }

  // Hover Interactions
  function highlightMarker(id) {
    const el = document.getElementById(`marker-${id}`);
    if (el) el.classList.add('active');
    
    const marker = markers[id];
    if (marker) {
      // Bring to front
      marker.setZIndexOffset(1000);
      // Pan map slightly to make sure it's visible if needed, 
      // but don't jump too much on hover.
    }
  }

  function unhighlightMarker(id) {
    const el = document.getElementById(`marker-${id}`);
    if (el) el.classList.remove('active');
    
    const marker = markers[id];
    if (marker) marker.setZIndexOffset(0);
  }

  document.addEventListener('DOMContentLoaded', initExploreMap);
</script>

