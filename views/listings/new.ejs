<% layout("/layouts/boilerplate") %>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <br /><br />
      <h3>Create a New Listing</h3>
      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required />

          <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter a short description</div>
        </div>

        <div class="mb-3">
          <label for="images" class="form-label">Upload Listing Photos <span class="text-muted fw-normal">(Up to 5 images)</span></label>
          <input name="listing[images]" id="imageInput" type="file" class="form-control" accept="image/*" multiple required />
          <div class="form-text text-muted">Select up to 5 photos. First image will be the cover photo.</div>
          <input type="hidden" name="coverIndex" id="coverIndexInput" value="0">
          <div id="imagePreview" class="d-flex gap-2 mt-2 flex-wrap"></div>
          <script>
            document.getElementById('imageInput').addEventListener('change', function() {
              const preview = document.getElementById('imagePreview');
              const coverInput = document.getElementById('coverIndexInput');
              preview.innerHTML = '';
              coverInput.value = '0'; // reset to first image
              
              const files = Array.from(this.files).slice(0, 5);
              files.forEach((file, i) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                  const wrapper = document.createElement('div');
                  wrapper.className = 'preview-wrapper';
                  wrapper.style.cssText = 'position:relative;display:inline-block;cursor:pointer;';
                  wrapper.dataset.index = i;
                  
                  const img = document.createElement('img');
                  img.src = e.target.result;
                  img.className = 'preview-img';
                  img.style.cssText = 'width:80px;height:60px;object-fit:cover;border-radius:8px;border:3px solid ' + (i === 0 ? '#fe424d' : '#ddd');
                  
                  const badge = document.createElement('span');
                  badge.className = 'cover-badge-ui';
                  badge.textContent = 'Cover';
                  badge.style.cssText = 'position:absolute;bottom:2px;left:2px;background:#fe424d;color:#fff;font-size:9px;padding:1px 4px;border-radius:4px;display:' + (i === 0 ? 'block' : 'none');
                  
                  wrapper.appendChild(img);
                  wrapper.appendChild(badge);
                  
                  wrapper.addEventListener('click', function() {
                    // Update hidden input
                    coverInput.value = this.dataset.index;
                    
                    // Reset all previews
                    document.querySelectorAll('.preview-wrapper').forEach(w => {
                      w.querySelector('img').style.borderColor = '#ddd';
                      w.querySelector('span').style.display = 'none';
                    });
                    
                    // Highlight selected
                    this.querySelector('img').style.borderColor = '#fe424d';
                    this.querySelector('span').style.display = 'block';
                  });
                  
                  preview.appendChild(wrapper);
                };
                reader.readAsDataURL(file);
              });
            });
          </script>

        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="1200" class="form-control" required />
            <div class="invalid-feedback">Price should be valid</div>
          </div>

          <div class="mb-3 col-md-4">
            <label for="taxRate" class="form-label">Tax Rate (%)</label>
            <input name="listing[taxRate]" type="number" placeholder="e.g., 18" class="form-control" min="0" max="100" />
            <div class="form-text text-muted">Optional tax percentage.</div>
          </div>

          <div class="mb-3 col-md-4">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" placeholder="India" type="text" class="form-control" required />
            <div class="invalid-feedback">Country name should be valid</div>
          </div>
          
          <div class="mb-3 col-md-4">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" class="form-select" required>
              <option value="" disabled selected>Select Category</option>
              <option value="Trending">Trending</option>
              <option value="Rooms">Rooms</option>
              <option value="Iconic Cities">Iconic Cities</option>
              <option value="Mountains">Mountains</option>
              <option value="Castels">Castels</option>
              <option value="Amezing Pool">Amezing Pool</option>
              <option value="Camping">Camping</option>
              <option value="Farms">Farms</option>
              <option value="Arctic">Arctic</option>
              <option value="Domes">Domes</option>
              <option value="Boats">Boats</option>
              <option value="Resort">Resort</option>
            </select>
            <div class="invalid-feedback">Please select a category.</div>
          </div>

          <div class="mb-md-3">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" id="locationInput" placeholder="Raipur, chhattisgarh" type="text" class="form-control"
              required />
            <input type="hidden" name="listing[lat]" id="latInput">
            <input type="hidden" name="listing[lng]" id="lngInput">
          </div>
          <div class="invalid-feedback">Location should be valid</div>

          <!-- 🗺️ Interactive Map Picker -->
          <div class="mb-4">
            <label class="form-label text-muted small"><i class="fa-solid fa-map-location-dot me-1"></i> Exact Location Picker (Search or drag pin)</label>
            <div id="pickerMap" style="height: 300px; width: 100%; border-radius: 1rem; border: 2px solid #eee;"></div>
            <div class="form-text text-muted">Use the search icon on the map or drag the pin to your exact spot.</div>
          </div>

          <script>
            document.addEventListener('DOMContentLoaded', () => {
              // --- Define Base Layers ---
              const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
              });

              const esriWorldImagery = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
                attribution: 'Tiles &copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community'
              });

              const esriWorldStreet = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}', {
                attribution: 'Tiles &copy; Esri &mdash; Source: Esri, DeLorme, NAVTEQ, USGS, Intermap, iPC, NRCAN, Esri Japan, METI, Esri China (Hong Kong), Esri (Thailand), TomTom, 2012'
              });

              // Initial Map setup
              const map = L.map('pickerMap', {
                layers: [esriWorldStreet] // Default layer
              }).setView([20.5937, 78.9629], 5);

              const baseMaps = {
                "Detailed Street": esriWorldStreet,
                "Satellite View": esriWorldImagery,
                "Standard (OSM)": osm
              };

              L.control.layers(baseMaps).addTo(map);

              let marker = L.marker([20.5937, 78.9629], { draggable: true }).addTo(map);
              const poiLayer = L.layerGroup().addTo(map);

              function updateFields(lat, lng, address) {
                document.getElementById('latInput').value = lat;
                document.getElementById('lngInput').value = lng;
                if (address) {
                  document.getElementById('locationInput').value = address;
                }
                fetchNearbyPOIs(lat, lng);
              }

              async function fetchNearbyPOIs(lat, lng) {
                try {
                  const resp = await fetch(`/api/map/discover?lat=${lat}&lng=${lng}&radius=1500`);
                  const pois = await resp.json();
                  poiLayer.clearLayers();
                  
                  pois.forEach(poi => {
                    const icon = L.divIcon({
                      className: 'poi-marker',
                      html: `<div style="background:#4285F4; width:10px; height:10px; border-radius:50%; border:2px solid white; box-shadow:0 0 5px rgba(0,0,0,0.3);"></div>`,
                      iconSize: [10, 10]
                    });
                    
                    const pMarker = L.marker([poi.lat, poi.lon], { icon })
                      .bindTooltip(poi.name, { permanent: false, direction: 'top' });
                    poiLayer.addLayer(pMarker);
                  });
                } catch (e) {
                  console.error("Discovery failed", e);
                }
              }

              // Geocoder with India/Chhattisgarh focus
              const geocoder = L.Control.geocoder({
                defaultMarkGeocode: false,
                placeholder: "Search (e.g. Raipur, Bhilai, Durg)...",
                geocoder: L.Control.geocoder.nominatim({
                  geocodingQueryParams: {
                    countrycodes: 'in',
                    viewbox: '81.0,21.0,82.0,22.0' // Focus near CG
                  }
                })
              }).on('markgeocode', function(e) {
                const latlng = e.geocode.center;
                map.setView(latlng, 17);
                marker.setLatLng(latlng);
                updateFields(latlng.lat, latlng.lng, e.geocode.name);
              }).addTo(map);

              // Update fields on drag end
              marker.on('dragend', function(e) {
                const latlng = marker.getLatLng();
                updateFields(latlng.lat, latlng.lng);
                
                fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latlng.lat}&lon=${latlng.lng}`)
                  .then(res => res.json())
                  .then(data => {
                    if (data.display_name) {
                      document.getElementById('locationInput').value = data.display_name;
                    }
                  });
              });

              map.on('click', function(e) {
                marker.setLatLng(e.latlng);
                updateFields(e.latlng.lat, e.latlng.lng);
              });

              // Initial POI fetch if map is at a specific location
              if(latInput.value && lngInput.value) {
                fetchNearbyPOIs(latInput.value, lngInput.value);
              }
            });
          </script>



          <div class="mb-3">
            <label for="maxGuests" class="form-label">Max Guests Allowed</label>
            <input name="listing[maxGuests]" placeholder="e.g. 4" type="number" class="form-control" min="1" required />
            <div class="form-text text-muted">How many guests can stay at your property?</div>
          </div>

        </div>

        <br /><br />
        <button class="btn btn-dark add-btn mt-3">Add</button>
        <br /><br />
      </form>
    </div>
  </div>