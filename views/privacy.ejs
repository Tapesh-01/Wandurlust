<% layout("/layouts/boilerplate") %>

<style>
  /* ── Light Mode Defaults ── */
  .privacy-hero {
    background: linear-gradient(135deg, #111111 0%, #2d0000 100%);
    color: white;
    padding: 64px 0 48px;
    margin-bottom: 0;
    transition: background 0.3s;
  }
  .privacy-hero h1 {
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.5px;
  }
  .privacy-hero p {
    color: #bbb;
    font-size: 1.1rem;
    margin-top: 8px;
  }
  .privacy-hero .badge-updated {
    display: inline-block;
    background: rgba(254,66,77,0.18);
    color: #fe424d;
    border: 1px solid rgba(254,66,77,0.35);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 18px;
    letter-spacing: 0.5px;
  }

  .privacy-nav {
    position: sticky;
    top: 72px;
    background: #fff;
    border-bottom: 1px solid #eee;
    z-index: 100;
    padding: 0;
    transition: background 0.3s, border-color 0.3s;
  }
  .privacy-nav .nav-link {
    color: #555;
    font-size: 13px;
    font-weight: 600;
    padding: 14px 18px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }
  .privacy-nav .nav-link:hover,
  .privacy-nav .nav-link.active {
    color: #fe424d;
    border-bottom-color: #fe424d;
  }

  .privacy-body {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .privacy-section {
    margin-bottom: 56px;
    scroll-margin-top: 130px;
  }
  .privacy-section h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #111;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f0f0f0;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: color 0.3s, border-color 0.3s;
  }
  .privacy-section h2 .sec-icon {
    background: #fff0f0;
    color: #fe424d;
    border-radius: 10px;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .privacy-section p,
  .privacy-section li {
    color: #444;
    font-size: 15.5px;
    line-height: 1.8;
    transition: color 0.3s;
  }
  .privacy-section ul {
    padding-left: 20px;
  }
  .privacy-section ul li {
    margin-bottom: 8px;
  }
  .privacy-section ul li::marker {
    color: #fe424d;
  }

  .highlight-box {
    background: #fff8f8;
    border-left: 4px solid #fe424d;
    border-radius: 0 12px 12px 0;
    padding: 20px 24px;
    margin: 24px 0;
    font-size: 14.5px;
    color: #555;
    transition: background 0.3s, color 0.3s;
  }

  .contact-card {
    background: linear-gradient(135deg, #111 0%, #2d0000 100%);
    border-radius: 20px;
    padding: 40px;
    color: white;
    margin-top: 40px;
    transition: background 0.3s;
  }
  .contact-card h3 {
    font-weight: 800;
    margin-bottom: 12px;
    font-size: 1.3rem;
  }
  .contact-card p { color: #bbb; font-size: 15px; margin-bottom: 6px; }
  .contact-card a { color: #fe424d; text-decoration: none; font-weight: 600; }
  .contact-card a:hover { text-decoration: underline; }

  /* ── Dark Mode Overrides ── */
  [data-theme="dark"] .privacy-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  }
  [data-theme="dark"] .privacy-nav {
    background: #0f172a;
    border-bottom-color: #334155;
  }
  [data-theme="dark"] .privacy-nav .nav-link {
    color: #94a3b8;
  }
  [data-theme="dark"] .privacy-section h2 {
    color: #f8fafc;
    border-bottom-color: #334155;
  }
  [data-theme="dark"] .privacy-section h2 .sec-icon {
    background: rgba(254,66,77,0.1);
  }
  [data-theme="dark"] .privacy-section p,
  [data-theme="dark"] .privacy-section li {
    color: #cbd5e1;
  }
  [data-theme="dark"] .highlight-box {
    background: rgba(30, 41, 59, 0.5);
    color: #94a3b8;
    border-left-color: #fe424d;
  }
  [data-theme="dark"] .contact-card {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border: 1px solid #334155;
  }

  @media (max-width: 768px) {
    .privacy-hero h1 { font-size: 2.1rem; }
    .privacy-nav .nav-link { padding: 12px 14px; font-size: 12px; }
    .privacy-body { padding: 32px 16px; }
  }
</style>

<!-- Hero -->
<div class="privacy-hero">
  <div class="container">
    <div class="privacy-body" style="padding-top:0; padding-bottom:0;">
      <span class="badge-updated">Last Updated: April 2026</span>
      <h1>Privacy &amp; Terms</h1>
      <p>How WanderLust manages your data and the rules for using our hospitality platform.</p>
    </div>
  </div>
</div>

<!-- Sticky nav -->
<div class="privacy-nav d-none d-md-block">
  <div class="container">
    <div class="privacy-body" style="padding:0;">
      <nav class="d-flex flex-wrap gap-0">
        <a href="#data" class="nav-link">Data Collection</a>
        <a href="#ai" class="nav-link">WanderBot AI</a>
        <a href="#usage" class="nav-link">How We Use It</a>
        <a href="#security" class="nav-link">Security</a>
        <a href="#cancellation" class="nav-link">Cancellation</a>
        <a href="#terms" class="nav-link">Terms of Use</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>
    </div>
  </div>
</div>

<!-- Body -->
<div class="container">
  <div class="privacy-body">

    <!-- 1. Data We Collect -->
    <div class="privacy-section" id="data">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-database"></i></span>
        1. Data We Collect
      </h2>
      <p>WanderLust collects information to provide a seamless booking experience:</p>
      <ul>
        <li><strong>Account Info</strong> — Username, email, and securely hashed passwords via Passport.js.</li>
        <li><strong>Listings &amp; Reviews</strong> — Content you post, including property details and ratings.</li>
        <li><strong>Images</strong> — Photos uploaded via Cloudinary for listings and profile customization.</li>
        <li><strong>Location Data</strong> — GPS coordinates for maps and distance calculations via Leaflet.js.</li>
      </ul>
      <div class="highlight-box">
        <i class="fa-solid fa-circle-info me-2" style="color:#fe424d;"></i>
        We do not store your raw passwords or payment card details. All financial transactions are handled by secure external providers.
      </div>
    </div>

    <!-- 2. WanderBot AI -->
    <div class="privacy-section" id="ai">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-robot"></i></span>
        2. WanderBot AI Assistant
      </h2>
      <p>Our WanderBot uses Google Gemini AI to assist you. Here’s how it handles data:</p>
      <ul>
        <li><strong>Chat History</strong> — We temporarily store your chat context to provide coherent replies during your session.</li>
        <li><strong>Listing Data</strong> — The bot analyzes our current database listings to give you real-time recommendations.</li>
        <li><strong>Privacy</strong> — Your messages are processed by AI models but are not used to build a personal profile of you.</li>
      </ul>
    </div>

    <!-- 3. How We Use It -->
    <div class="privacy-section" id="usage">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-gears"></i></span>
        3. How We Use Your Data
      </h2>
      <p>Your information is used solely for the operation of WanderLust:</p>
      <ul>
        <li>To facilitate bookings between guests and hosts.</li>
        <li>To display accurate maps and travel distances for your selected stays.</li>
        <li>To send notifications about your bookings and messages.</li>
        <li>To improve our AI WanderBot's accuracy and helpfulness.</li>
      </ul>
      <p>We have a **Zero Spam** policy. Your email is never sold to third-party marketers.</p>
    </div>

    <!-- 4. Security -->
    <div class="privacy-section" id="security">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-shield-halved"></i></span>
        4. Security Measures
      </h2>
      <p>We protect your data using industry-standard protocols:</p>
      <ul>
        <li><strong>SSL Encryption</strong> — All data transferred is encrypted via HTTPS.</li>
        <li><strong>Secure Storage</strong> — Images are hosted on Cloudinary, and data is stored in MongoDB Atlas with strict access controls.</li>
        <li><strong>Session Protection</strong> — Secure cookies ensure your login stays private and protected from hijacking.</li>
      </ul>
    </div>

    <!-- 5. Cancellation -->
    <div class="privacy-section" id="cancellation">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-ban"></i></span>
        5. Cancellation Policy
      </h2>
      <p>To ensure fairness for both hosts and guests:</p>
      <ul>
        <li>Bookings can be cancelled from your dashboard before the check-in date.</li>
        <li>Refund policies are determined by the individual host's settings at the time of listing.</li>
        <li>WanderLust handles the platform-level coordination of cancellations and calendar updates.</li>
      </ul>
    </div>

    <!-- 6. Terms of Use -->
    <div class="privacy-section" id="terms">
      <h2>
        <span class="sec-icon"><i class="fa-solid fa-file-contract"></i></span>
        6. Terms of Use
      </h2>
      <p>By using WanderLust, you agree to:</p>
      <ul>
        <li>Provide truthful information in your listings and reviews.</li>
        <li>Respect the privacy and property of other users.</li>
        <li>Not attempt to exploit or disrupt our AI systems or mapping services.</li>
        <li>Be responsible for all activities that occur under your account.</li>
      </ul>
    </div>

    <!-- Contact Card -->
    <div class="contact-card" id="contact">
      <h3><i class="fa-solid fa-headset me-2"></i> Need Help?</h3>
      <p>For any questions regarding these terms, feel free to contact our team:</p>
      <p>📧 Email: <a href="mailto:support@wanderlust.com">support@wanderlust.com</a></p>
      <p>📍 Address: Harinagar, Durg, Chhattisgarh, India 491001</p>
      <p style="margin-top:16px; font-size:13px; color:rgba(255,255,255,0.5);">© 2026 WanderLust Hospitality. All rights reserved.</p>
    </div>

  </div>
</div>

<script>
  // Highlight active nav link on scroll
  const sections = document.querySelectorAll('.privacy-section, #contact');
  const navLinks = document.querySelectorAll('.privacy-nav .nav-link');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(l => l.classList.remove('active'));
        const active = document.querySelector(`.privacy-nav a[href="#${entry.target.id}"]`);
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => observer.observe(s));
</script>
